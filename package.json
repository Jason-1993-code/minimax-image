{
  "name": "@openclaw/minimax-image-ng",
  "version": "1.2.1",
  "description": "MiniMax image generation provider for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23-2",
      "minGatewayVersion": "2026.3.23-2"
    },
    "build": {
      "openclawVersion": "2026.3.23-2",
      "pluginSdkVersion": "2026.3.23-2"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "*",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "image-generation",
    "minimax"
  ],
  "license": "MIT"
}
